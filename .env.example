# Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Scanner runtime
MAX_WORKERS=2
CACHE_TTL_HOURS=18
FETCH_RETRIES=3
REQUEST_TIMEOUT=10

# 1차 필터 / 기술 필터
FIRST_PASS_MIN_CLOSE=500
FIRST_PASS_MIN_AMOUNT=1000000000
MIN_AVG_TURNOVER=1000000000
MIN_ADR=1.5

# Report / sending
TOP_SEND_LIMIT=20
SEND_CHARTS=true
FORCE_REFRESH=false
